# Copy this file to ".env" and fill in real values. .env is gitignored.

# Google Gemini API key (used for OCR). You already have one for tango-app,
# but rotate it and use a fresh key here.
GEMINI_API_KEY=your_gemini_key_here

# ElevenLabs API key (used for text-to-speech). Get it at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Optional: ElevenLabs voice id. Defaults to "Rachel" (a clear US English voice).
# Browse voices in the ElevenLabs dashboard to pick another.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Port the relay server listens on.
PORT=8787

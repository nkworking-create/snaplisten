# Copy this file to ".env" and fill in real values. .env is gitignored.

# Google Gemini API key. Used for OCR AND for the free TTS voice.
# (Rotate the old tango-app key and use a fresh one here.)
GEMINI_API_KEY=your_gemini_key_here

# TTS provider: "gemini" (free, default) or "elevenlabs" (premium, paid tier).
# Can also be overridden per request with { "provider": "elevenlabs" }.
TTS_PROVIDER=gemini

# Gemini TTS voice (free path). Other options: Puck, Charon, Aoede, Leda...
GEMINI_TTS_VOICE=Kore

# ElevenLabs — only needed when using the premium path.
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Port the relay server listens on.
PORT=8787

# --- v1.1: Apple App Store Server API (for IAP receipt verification) ---
# Generate the key in App Store Connect:
#   Users and Access → Integrations → In-App Purchase / App Store Server API → Generate Key
# Download the .p8 file ONCE — Apple won't show it again.
APPLE_KEY_ID=                    # the 10-char key ID shown next to your key
APPLE_ISSUER_ID=                 # the UUID at the top of the keys page
APPLE_BUNDLE_ID=app.snaplisten   # must match the iOS bundle id

# The .p8 contents, base64-encoded so it survives env var serialization:
#   PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("AuthKey_XXXXX.p8"))
APPLE_PRIVATE_KEY_BASE64=
